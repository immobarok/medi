model User {
  id           String     @id @default(uuid()) @db.Uuid
  hospitalId   String?    @map("hospital_id") @db.Uuid
  fullName     String     @map("full_name") @db.VarChar(150)
  email        String     @unique @db.VarChar(150)
  phone        String?    @db.VarChar(30)
  passwordHash String     @map("password_hash")
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamp(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamp(6)

  hospital               Hospital?         @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  roles                  UserRole[]
  doctorProfile          Doctor?           @relation("DoctorUser")
  createdAppointments    Appointment[]     @relation("AppointmentCreatedBy")
  createdQueueTokens     QueueToken[]      @relation("QueueTokenCreatedBy")
  calledQueueTokens      QueueToken[]      @relation("QueueTokenCalledBy")
  completedQueueTokens   QueueToken[]      @relation("QueueTokenCompletedBy")
  performedQueueEvents   QueueTokenEvent[] @relation("QueueEventPerformedBy")
  auditLogs              AuditLog[]

  @@index([hospitalId])
  @@index([email])
  @@index([phone])
  @@map("users")
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @db.VarChar(80)
  code        String  @unique @db.VarChar(50)
  description String?

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id   String @id @default(uuid()) @db.Uuid
  name String @db.VarChar(120)
  code String @unique @db.VarChar(100)

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}
